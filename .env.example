# ============================================================================
# FamilyHub Environment Variables
# Copy this file to .env and fill in your values
# ============================================================================

# ============================================================================
# Core Configuration
# ============================================================================
NODE_ENV=development
PORT=3000

# ============================================================================
# Database (Vercel Postgres - auto-provided in production)
# ============================================================================
# For local development, use your own PostgreSQL instance
# For Vercel deployment, this is auto-set by Vercel
DATABASE_URL=postgresql://user:password@localhost:5432/familyhub

# ============================================================================
# Authentication (Clerk)
# Get these from https://dashboard.clerk.com
# ============================================================================
CLERK_SECRET_KEY=sk_test_your_secret_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# ============================================================================
# Payments (Stripe) - Optional, add later if needed
# Get these from https://dashboard.stripe.com
# ============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret

# ============================================================================
# Email (SendGrid) - Optional, add later if needed
# Get API key from https://app.sendgrid.com/settings/api_keys
# ============================================================================
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@familyhub.local

# ============================================================================
# Real-time Communication (Pusher) - Optional
# Get these from https://dashboard.pusher.com
# ============================================================================
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=mt1

# ============================================================================
# Analytics & Monitoring
# ============================================================================

# Google Analytics 4
# Get this from https://analytics.google.com
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Mixpanel (optional)
# Get this from https://mixpanel.com
VITE_MIXPANEL_TOKEN=your_mixpanel_token

# Sentry Error Tracking (FREE tier: 5,000 errors/month)
# Get DSN from https://sentry.io
VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACE_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=1.0

# ============================================================================
# Application Configuration
# ============================================================================
VITE_APP_VERSION=1.0.0
VITE_API_URL=http://localhost:3000/api

# ============================================================================
# Optional: Microsoft Graph (for calendar integration)
# ============================================================================
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT_ID=your_microsoft_tenant_id

# ============================================================================
# Optional: Google Calendar Integration
# ============================================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============================================================================
# Optional: OpenAI (for AI features)
# ============================================================================
OPENAI_API_KEY=sk-your_openai_api_key

# ============================================================================
# Optional: Anthropic Claude (for AI features)
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key
